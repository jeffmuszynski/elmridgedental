<script>
(() => {
  const validSections = new Set(["fillings","crowns","extractions","implants","bone-graft","root-canal","deep-cleaning","whitening","immediate-dentures"]);
  const openFromHash = () => {
    const hash = decodeURIComponent(window.location.hash || '').replace(/^#/, '');
    const sections = document.querySelectorAll('[data-post-op-section]');
    sections.forEach(section => { section.open = false; });
    if (!validSections.has(hash)) return;
    const target = document.getElementById(hash);
    if (!target) return;
    target.open = true;
    window.requestAnimationFrame(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }));
  };
  window.addEventListener('DOMContentLoaded', openFromHash);
  window.addEventListener('hashchange', openFromHash);
})();
</script>
