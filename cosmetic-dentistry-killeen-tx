<script>
  const smileForm = document.getElementById("smileSimulatorForm");
  const smilePhoto = document.getElementById("smilePhoto");
  const smileConsent = document.getElementById("smileConsent");
  const smileButton = document.getElementById("smileSubmitButton");
  const smileName = document.getElementById("smileName");
const smilePhone = document.getElementById("smilePhone");
const smileEmail = document.getElementById("smileEmail");
const smileMessage = document.getElementById("smileMessage");
  const smileError = document.getElementById("smileError");
  const smileLoading = document.getElementById("smileLoading");
const smileLoadingText = document.getElementById("smileLoadingText");
let smileLoadingInterval = null;
  const smileResults = document.getElementById("smileResults");
  const beforeSmileImage = document.getElementById("beforeSmileImage");
  const afterSmileImage = document.getElementById("afterSmileImage");
  const smileCta = document.getElementById("smileCta");
  const downloadSmileComposite = document.getElementById("downloadSmileComposite");

  const SMILE_ATTEMPT_LIMIT = 2;
const SMILE_ATTEMPT_WINDOW_HOURS = 24;
const SMILE_POLL_INTERVAL_MS = 5000;
const SMILE_MAX_WAIT_MS = 3 * 60 * 1000;
const SMILE_MAX_UPLOAD_BYTES = 5 * 1024 * 1024;
const SMILE_TARGET_UPLOAD_BYTES = 2.5 * 1024 * 1024;
const SMILE_MAX_IMAGE_DIMENSION = 1400;

function getSmileAttempts() {
  try {
    const stored = localStorage.getItem("smilePreviewAttempts");

    if (!stored) {
      return [];
    }

    const attempts = JSON.parse(stored);
    const now = Date.now();
    const windowMs = SMILE_ATTEMPT_WINDOW_HOURS * 60 * 60 * 1000;

    return attempts.filter((timestamp) => now - timestamp < windowMs);
  } catch {
    return [];
  }
}

function saveSmileAttempt() {
  const attempts = getSmileAttempts();
  attempts.push(Date.now());
  localStorage.setItem("smilePreviewAttempts", JSON.stringify(attempts));
}

function hasReachedSmileLimit() {
  return getSmileAttempts().length >= SMILE_ATTEMPT_LIMIT;
}

async function readSmileJsonResponse(response, fallbackMessage) {
  const responseText = await response.text();

  try {
    return responseText ? JSON.parse(responseText) : {};
  } catch {
    throw new Error(`${fallbackMessage} (${response.status})`);
  }
}

function wait(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function loadSmileUploadImage(file) {
  return new Promise((resolve, reject) => {
    const image = new Image();
    const imageUrl = URL.createObjectURL(file);

    image.onload = () => {
      URL.revokeObjectURL(imageUrl);
      resolve(image);
    };

    image.onerror = () => {
      URL.revokeObjectURL(imageUrl);
      reject(new Error("This photo could not be read. Please try a clear JPG, PNG, or WebP image."));
    };

    image.src = imageUrl;
  });
}

function canvasToBlob(canvas, type, quality) {
  return new Promise((resolve) => {
    canvas.toBlob(resolve, type, quality);
  });
}

async function prepareSmileUploadFile(file) {
  const allowedTypes = ["image/jpeg", "image/png", "image/webp"];

  if (file.type && !allowedTypes.includes(file.type)) {
    throw new Error("Please upload a JPG, PNG, or WebP image.");
  }

  const image = await loadSmileUploadImage(file);
  const largestSide = Math.max(image.naturalWidth || image.width, image.naturalHeight || image.height);
  const scale = Math.min(1, SMILE_MAX_IMAGE_DIMENSION / largestSide);
  let width = Math.max(1, Math.round((image.naturalWidth || image.width) * scale));
  let height = Math.max(1, Math.round((image.naturalHeight || image.height) * scale));
  let quality = 0.84;
  let compressedBlob = null;

  for (let attempt = 0; attempt < 5; attempt += 1) {
    const canvas = document.createElement("canvas");
    const ctx = canvas.getContext("2d");

    canvas.width = width;
    canvas.height = height;
    ctx.drawImage(image, 0, 0, width, height);

    compressedBlob = await canvasToBlob(canvas, "image/jpeg", quality);

    if (compressedBlob && compressedBlob.size <= SMILE_TARGET_UPLOAD_BYTES) {
      break;
    }

    width = Math.max(1, Math.round(width * 0.86));
    height = Math.max(1, Math.round(height * 0.86));
    quality = Math.max(0.68, quality - 0.06);
  }

  if (!compressedBlob || compressedBlob.size > SMILE_MAX_UPLOAD_BYTES) {
    throw new Error("This photo is too large to upload from mobile. Please choose a smaller image or screenshot of the smile photo.");
  }

  if (typeof File === "function") {
    return new File([compressedBlob], "smile-photo.jpg", {
      type: "image/jpeg",
      lastModified: Date.now(),
    });
  }

  compressedBlob.name = "smile-photo.jpg";
  return compressedBlob;
}

async function startSmilePreviewJob(formData) {
  const response = await fetch("/api/smile-simulation/start", {
    method: "POST",
    body: formData
  });
  const data = await readSmileJsonResponse(response, "Smile simulation failed to start. Please refresh the page and try again.");

  if (!response.ok || !data.jobId) {
    throw new Error(data.error || "Smile simulation failed to start.");
  }

  return data.jobId;
}

async function getSmilePreviewStatus(jobId) {
  const response = await fetch(`/api/smile-simulation/status?jobId=${encodeURIComponent(jobId)}`, {
    method: "GET",
    headers: {
      Accept: "application/json"
    }
  });
  const data = await readSmileJsonResponse(response, "Smile simulation status could not be read. Please try again.");

  if (!response.ok) {
    throw new Error(data.error || "Smile simulation status could not be read.");
  }

  return data;
}

async function waitForSmilePreview(jobId) {
  const startedAt = Date.now();

  while (Date.now() - startedAt < SMILE_MAX_WAIT_MS) {
    await wait(SMILE_POLL_INTERVAL_MS);
    let data;

    try {
      data = await getSmilePreviewStatus(jobId);
    } catch (error) {
      if (error.name === "TypeError") {
        continue;
      }

      throw error;
    }

    if (data.status === "complete") {
      if (!data.imageUrl) {
        throw new Error("Smile simulation completed without an image. Please try again.");
      }

      return data.imageUrl;
    }

    if (data.status === "error") {
      throw new Error(data.error || "Smile simulation failed. Please try another clear smile photo.");
    }
  }

  throw new Error("Your smile preview is taking longer than expected. Please try again, or call our office and we can help.");
}

async function decodeSmileImage(image) {
  if (image.decode) {
    await image.decode();
    return;
  }

  if (image.complete && image.naturalWidth > 0) return;

  await new Promise((resolve, reject) => {
    image.onload = resolve;
    image.onerror = reject;
  });
}

function loadImageForCanvas(src) {
  return new Promise((resolve, reject) => {
    const image = new Image();
    image.onload = () => resolve(image);
    image.onerror = reject;
    image.src = src;
  });
}

function drawImageCover(ctx, image, x, y, width, height) {
  const imageRatio = image.width / image.height;
  const boxRatio = width / height;

  let drawWidth = width;
  let drawHeight = height;
  let offsetX = 0;
  let offsetY = 0;

  if (imageRatio > boxRatio) {
    drawHeight = height;
    drawWidth = height * imageRatio;
    offsetX = (width - drawWidth) / 2;
  } else {
    drawWidth = width;
    drawHeight = width / imageRatio;
    offsetY = (height - drawHeight) / 2;
  }

  ctx.drawImage(image, x + offsetX, y + offsetY, drawWidth, drawHeight);
}

async function createSmileCompositeDataUrl() {
  if (!beforeSmileImage.src || !afterSmileImage.src) {
    throw new Error("Please generate a smile preview first.");
  }

    const beforeImage = await loadImageForCanvas(beforeSmileImage.src);
    const afterImage = await loadImageForCanvas(afterSmileImage.src);
    let logoImage = null;

    try {
      logoImage = await loadImageForCanvas("/square logo.webp");
    } catch {
      logoImage = null;
    }

    const canvas = document.createElement("canvas");
    const ctx = canvas.getContext("2d");

    const width = 1600;
    const height = 1300;
    const padding = 60;
    const imageGap = 40;
    const imageWidth = (width - padding * 2 - imageGap) / 2;
    const imageHeight = 790;
    const imageY = padding;
    const footerGap = 44;
    const footerY = imageY + imageHeight + footerGap;
    const footerHeight = height - footerY - padding;

    canvas.width = width;
    canvas.height = height;

    ctx.fillStyle = "#f7f4ef";
    ctx.fillRect(0, 0, width, height);

    const beforeX = padding;
    const afterX = padding + imageWidth + imageGap;

    ctx.fillStyle = "#ffffff";
    ctx.fillRect(beforeX, imageY, imageWidth, imageHeight);
    ctx.fillRect(afterX, imageY, imageWidth, imageHeight);

    drawImageCover(ctx, beforeImage, beforeX, imageY, imageWidth, imageHeight);
    drawImageCover(ctx, afterImage, afterX, imageY, imageWidth, imageHeight);

    ctx.fillStyle = "#2C3E3E";
    ctx.fillRect(padding, footerY, width - padding * 2, footerHeight);

    if (logoImage) {
      ctx.fillStyle = "#ffffff";
      ctx.fillRect(padding + 34, footerY + 42, 116, 116);
      ctx.drawImage(logoImage, padding + 44, footerY + 52, 96, 96);
    }

    const footerTextX = logoImage ? padding + 184 : padding + 34;

    ctx.fillStyle = "#ffffff";
    ctx.font = "bold 34px Arial, sans-serif";
    ctx.fillText("Elm Ridge Implant and Family Dentistry", footerTextX, footerY + 58);

    ctx.font = "24px Arial, sans-serif";
    ctx.fillText("Cosmetic Dentistry Consultation", footerTextX, footerY + 96);

    ctx.fillStyle = "#A8D4D4";
    ctx.font = "bold 24px Arial, sans-serif";
    ctx.fillText("254-699-4127", footerTextX, footerY + 148);
    ctx.fillText("www.elmridgedental.com", footerTextX + 220, footerY + 148);
    ctx.fillText("2601 E. Elms Rd, Killeen, TX 76542", footerTextX, footerY + 188);

    ctx.fillStyle = "rgba(255,255,255,0.72)";
    ctx.font = "18px Arial, sans-serif";
    ctx.fillText("This image is a simulation and is not a diagnosis, treatment plan, or guarantee of outcome.", footerTextX, footerY + footerHeight - 28);

    return canvas.toDataURL("image/png");
}

async function downloadSmileCompositeImage() {
  try {
    const compositeDataUrl = await createSmileCompositeDataUrl();
    const link = document.createElement("a");
    link.download = "elm-ridge-smile-simulation-before-after.png";
    link.href = compositeDataUrl;
    link.click();
  } catch (error) {
    smileError.textContent = error.message || "Could not download the smile simulation image. Please try again.";
    smileError.style.display = "block";
  }
}

async function emailSmileCompositeImage() {
  try {
    const compositeDataUrl = await createSmileCompositeDataUrl();
    const response = await fetch("/api/smile-simulation-email", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        name: smileName.value.trim(),
        phone: smilePhone.value.trim(),
        email: smileEmail.value.trim(),
        message: smileMessage.value.trim(),
        compositeImage: compositeDataUrl,
      }),
    });

    if (!response.ok) {
      throw new Error("Smile simulation email failed.");
    }
  } catch (error) {
    console.warn(error);
  }
}

if (downloadSmileComposite) {
  downloadSmileComposite.addEventListener("click", downloadSmileCompositeImage);
}

  smileForm.addEventListener("submit", async function (event) {
    event.preventDefault();

    smileError.style.display = "none";
    smileError.textContent = "";

    const file = smilePhoto.files[0];

    if (!smileName.value.trim()) {
  smileError.textContent = "Please enter your name before generating a smile preview.";
  smileError.style.display = "block";
  return;
}

if (!smilePhone.value.trim()) {
  smileError.textContent = "Please enter your phone number before generating a smile preview.";
  smileError.style.display = "block";
  return;
}

    if (!file) {
      smileError.textContent = "Please upload a clear smile photo.";
      smileError.style.display = "block";
      return;
    }

    if (!smileConsent.checked) {
      smileError.textContent = "Please confirm the simulation disclaimer before continuing.";
      smileError.style.display = "block";
      return;
    }

    if (hasReachedSmileLimit()) {
  smileError.textContent = "You have reached the smile preview limit. Please contact our office to schedule a cosmetic consultation.";
  smileError.style.display = "block";
  return;
}

    let uploadFile;

    try {
      uploadFile = await prepareSmileUploadFile(file);
    } catch (error) {
      smileError.textContent = error.message || "This photo could not be prepared. Please try another clear smile photo.";
      smileError.style.display = "block";
      return;
    }

    const beforeImageUrl = URL.createObjectURL(file);
    beforeSmileImage.src = beforeImageUrl;
    afterSmileImage.removeAttribute("src");
    smileResults.style.display = "none";
    smileCta.style.display = "none";

    smileButton.disabled = true;
smileButton.textContent = "Creating smile preview...";
smileLoading.style.display = "block";

let secondsElapsed = 0;
smileLoadingText.textContent = "Results may take 1–2 minutes. Please keep this page open.";

smileLoadingInterval = setInterval(() => {
  secondsElapsed += 15;

  if (secondsElapsed === 30) {
    smileLoadingText.textContent = "Still working. The AI is creating your simulated cosmetic result.";
  }

  if (secondsElapsed === 60) {
    smileLoadingText.textContent = "Almost there. Smile previews can take 1–2 minutes.";
  }

  if (secondsElapsed === 90) {
    smileLoadingText.textContent = "Still processing. Please do not refresh or close this page.";
  }
}, 15000);

    try {
      const formData = new FormData();
      formData.append("name", smileName.value.trim());
      formData.append("phone", smilePhone.value.trim());
      formData.append("email", smileEmail.value.trim());
      formData.append("message", smileMessage.value.trim());
      formData.append("image", uploadFile, "smile-photo.jpg");

      const jobId = await startSmilePreviewJob(formData);
      const imageUrl = await waitForSmilePreview(jobId);
      afterSmileImage.src = imageUrl;
      await Promise.all([
        decodeSmileImage(beforeSmileImage),
        decodeSmileImage(afterSmileImage),
      ]);
      smileResults.style.display = "grid";
      saveSmileAttempt();
      smileCta.style.display = "block";
      emailSmileCompositeImage();
    } catch (error) {
      smileError.textContent = error.message || "Smile simulation failed. Please try another photo.";
      smileError.style.display = "block";
    } finally {
  smileButton.disabled = false;
  smileButton.textContent = "Generate Smile Preview";
  smileLoading.style.display = "none";

  if (smileLoadingInterval) {
    clearInterval(smileLoadingInterval);
    smileLoadingInterval = null;
  }
}
  });
</script>
